model Property {
  id          String         @id @default(uuid())
  title       String
  description String
  location    String
  price       Float
  status      PropertyStatus @default(AVAILABLE)
  landlordId  String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Relations
  landlord User      @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@map("properties")
}