              "host": [ "{{base_url}}" ],
              "path": [ "api", "bookings", "booking_id_here", "update-status" ]
            },
            "description": "Status can be APPROVED or REJECTED."
          }
        },
        {
          "name": "Get All Bookings (Admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/bookings",
              "host": [ "{{base_url}}" ],
              "path": [ "api", "bookings" ]
            }
