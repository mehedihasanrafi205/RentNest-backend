    {
      "name": "Properties",
      "item": [
        {
          "name": "Create Listing (Landlord)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{landlord_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Beautiful 2BHK Apartment\",\n  \"description\": \"A very nice apartment with sea view.\",\n  \"location\": \"Dhaka\",\n  \"price\": 15000,\n  \"categoryId\": \"insert_category_id_here\",\n  \"amenities\": [\"WiFi\", \"Parking\", \"Gym\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/properties/create-listing",
              "host": [ "{{base_url}}" ],
              "path": [ "api", "properties", "create-listing" ]
            }
          }
        },
        {
          "name": "Get All Properties (With Filters)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/properties?location=Dhaka&minPrice=1000&maxPrice=50000",
              "host": [ "{{base_url}}" ],
              "path": [ "api", "properties" ],
              "query": [
                { "key": "location", "value": "Dhaka" },
                { "key": "minPrice", "value": "1000" },
                { "key": "maxPrice", "value": "50000" },
                { "key": "categoryId", "value": "", "disabled": true },
                { "key": "amenities", "value": "WiFi,Gym", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Single Property",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/properties/property_id_here",
              "host": [ "{{base_url}}" ],
              "path": [ "api", "properties", "property_id_here" ]
            }
          }
        }
      ]
