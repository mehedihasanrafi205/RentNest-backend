{
  "info": {
    "name": "RentNest Backend API",
    "description": "Complete API documentation for RentNest Property Rental Backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"tenant@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"TENANT\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": [ "{{base_url}}" ],
              "path": [ "api", "auth", "register" ]
            },
            "description": "Register a new user (Role can be TENANT, LANDLORD, or ADMIN)."
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tenant@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": [ "{{base_url}}" ],
              "path": [ "api", "auth", "login" ]
            }
          }
        }
      ]
    },
