            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"propertyId\": \"insert_property_id_here\",\n  \"startDate\": \"2026-08-01T00:00:00Z\",\n  \"endDate\": \"2026-08-31T00:00:00Z\"\n}"
            },
            "url": {
